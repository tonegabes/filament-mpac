{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "tonegabes/filament-mpac",
  "type": "project",
  "description": "The skeleton application for the MPs",
  "keywords": [
    "laravel",
    "framework",
    "mpac",
    "filament",
    "tonegabes"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "al-saloul/filament-image-gallery": "^3.0",
    "codeat3/blade-phosphor-icons": "^2.3",
    "directorytree/ldaprecord-laravel": "^3.4.2",
    "filament/filament": "~5.0",
    "filament/spatie-laravel-media-library-plugin": "~5.0",
    "filament/spatie-laravel-settings-plugin": "~5.0",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0",
    "opcodesio/log-viewer": "^3.19",
    "spatie/laravel-activitylog": "^5.0",
    "spatie/laravel-pdf": "^2.1",
    "spatie/laravel-permission": "^6.21",
    "tonegabes/filament-better-options": "^1.3",
    "tonegabes/filament-phosphor-icons": "^1.3"
  },
  "require-dev": {
    "barryvdh/laravel-ide-helper": "^3.6",
    "fakerphp/faker": "^1.24.1",
    "friendsofphp/php-cs-fixer": "^3.88.2",
    "larastan/larastan": "^3.7.2",
    "laravel/boost": "^2.0",
    "laravel/pail": "^1.2.3",
    "laravel/pint": "^1.25.1",
    "laravel/sail": "^1.46",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.8.2",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-faker": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan-deprecation-rules": "^2.0.3",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "dd:check": "laradumps check stop-on-failure --dir=app,routes,config,resources,database --text=dump,dd",
    "style:check": [
      "pint --test --no-interaction --ansi"
    ],
    "style:fix": [
      "pint --no-interaction --ansi"
    ],
    "code:analyze": [
      "phpstan analyze --memory-limit=4G --no-progress --no-interaction --ansi"
    ],
    "post-autoload-dump": [
      "@php artisan config:clear",
      "@php artisan clear-compiled",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "update:requirements": [
      "composer bump",
      "npx npm-check-updates -u"
    ],
    "fresh:db": [
      "@php artisan migrate:fresh --seed"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
